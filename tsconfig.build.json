{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/web/**", "tests/**", "node_modules", "dist"]
}
